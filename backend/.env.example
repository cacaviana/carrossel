# ============================================
# Carrossel System — Chaves necessarias
# ============================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
# ============================================

# Claude API (para geracao de conteudo dos slides)
# Obtenha em: https://console.anthropic.com/
CLAUDE_API_KEY=

# Gemini API (para geracao de imagens dos slides)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Drive — JSON da Service Account (para salvar PDF + PNGs)
# Cole o JSON inteiro da service account aqui (sem quebras de linha)
# Obtenha em: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_DRIVE_CREDENTIALS=

# Google Drive — ID da pasta raiz onde os carrosseis serao salvos
# Compartilhe a pasta com o email da service account acima
GOOGLE_DRIVE_FOLDER_ID=
