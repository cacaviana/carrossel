# ============================================
# Carrossel System — Chaves necessarias
# ============================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
# ============================================

# Claude API (geracao de conteudo dos slides via Anthropic)
# Obtenha em: https://console.anthropic.com/
CLAUDE_API_KEY=

# OpenAI API (fallback de conteudo quando Claude falha)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Gemini API (geracao de imagens dos slides + DNA visual)
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Drive — JSON da Service Account (salvar PDF + PNGs)
# Cole o JSON inteiro da service account aqui (sem quebras de linha)
# Obtenha em: https://console.cloud.google.com/iam-admin/serviceaccounts
GOOGLE_DRIVE_CREDENTIALS=

# Google Drive — ID da pasta raiz onde os carrosseis serao salvos
# Compartilhe a pasta com o email da service account acima
GOOGLE_DRIVE_FOLDER_ID=

# MongoDB / Cosmos DB (brand assets: refs, avatares, foto)
# Formato: mongodb://... ou mongodb+srv://...
# Pode usar Cosmos DB com API Mongo
MONGO_URL=

# SQL Server / Azure SQL (pipeline, steps, conteudo, imagens, scores)
# Formato SQLAlchemy async: mssql+aioodbc://USER:PASS@HOST/DB?driver=ODBC+Driver+17+for+SQL+Server
# MARS_Connection=yes eh adicionado automaticamente pelo codigo
MSSQL_URL=
